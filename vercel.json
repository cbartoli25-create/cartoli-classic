  input: { width:"100%", background:"#0d1b2a", border:"1px solid #2a3a50", borderRadius:8, padding:"10px 12px", color:"#fff", fontSize:14, marginBottom:8, boxSizing:"border-box" },

  holeScroll: { display:"flex", gap:5, flexWrap:"wrap", justifyContent:"center", marginBottom:14 },
