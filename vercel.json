  primaryBtn: { width:"100%", background:"linear-gradient(135deg,#C9A84C,#F0C040)", border:"none", borderRadius:12, padding:"15px", color:"#0d1b2a", fontSize:16, fontWeight:700, cursor:"pointer", marginBottom:10 },
