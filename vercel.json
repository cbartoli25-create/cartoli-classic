  spinner: { width:36, height:36, border:"3px solid #1e2a3a", borderTop:"3px solid #C9A84C", borderRadius:"50%", animation:"spin 1s linear infinite" },

  header: { background:"linear-gradient(160deg, #0B2545 0%, #1A4F7A 100%)", padding:"24px 20px 20px", textAlign:"center", position:"relative", overflow:"hidden" },
